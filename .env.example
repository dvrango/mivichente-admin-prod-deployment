# Vichente Admin — variables de entorno
# Copia este archivo a .env.local y rellena con valores reales.
# Nunca commitear .env.local.
# Las vars se validan en src/lib/env.ts — el build falla si falta una.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo server-side. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=
